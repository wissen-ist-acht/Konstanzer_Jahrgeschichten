                <pb n="205r"/>
                <ab n="1356">
                    Anno d<choice><abbr>m<am>-</am></abbr><expan>omini</expan></choice> m° ccc° lvi jor bredigit bru<hi rend="sup">o</hi><choice><abbr>d<am>9</am></abbr><expan>der</expan></choice> bechtol zu<hi rend="sup">o</hi> costancz <choice><abbr>ze<am>-</am></abbr><expan>zem</expan></choice> <choice><abbr>erste<am>-</am></abbr><expan>ersten</expan></choice><lb/> 
                </ab>
                <ab n="1332">
                    Anno m° ccc° xxx ii jor in marcio wart gemartet der gu<hi rend="sup">o</hi>t <choice><abbr>he<am>'</am></abbr><expan>her</expan></choice><lb/>
                    sant v<hi rend="sup">o</hi>lrich von den <choice><abbr>jude<am>-</am></abbr><expan>juden</expan></choice> zu<hi rend="sup">o</hi> <choice><abbr>überlinge<am>-</am></abbr><expan>überlingen</expan></choice> was eins ledergerwers<lb/>
                    sun hies der frye
                </ab>
                <ab n="1338">
